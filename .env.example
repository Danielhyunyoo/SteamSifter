# Copy this file to ".env" and fill in your key(s). The .env file is gitignored,
# so your keys never get committed.

# Which AI provider to use: "gemini" (free tier) or "openai" (pay-as-you-go).
LLM_PROVIDER=gemini

# Gemini key, from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# OpenAI key, from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Optional: force a specific model. Leave blank to use the provider default
# (gemini-2.5-flash-lite for gemini, gpt-4.1-mini for openai).
LLM_MODEL=
